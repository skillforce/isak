---
import "../styles/fonts.css";
import bgPrimary960 from "../assets/backgroundPrimary-960.avif";
import bgPrimary1600 from "../assets/backgroundPrimary-1600.avif";
import bgSecondary from "../assets/backgroundSecondary.avif";
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>Гера2 – Аппарат для удаления коррозии</title>

    <meta
      name="description"
      content="Гера2 – мощный и надежный пескоструйный аппарат для эффективной очистки и обработки поверхностей."
    />
    <meta
      name="keywords"
      content="Гера2, пескоструйный аппарат, пескоструй, очистка, обработка поверхностей, промышленное оборудование"
    />
    <meta name="author" content="Gera2 / Гера2" />

    <!-- Open Graph for social media -->
    <meta property="og:title" content="Гера2 – Пескоструйный аппарат" />
    <meta
      property="og:description"
      content="Гера2 – надежное решение для пескоструйной обработки и очистки поверхностей."
    />
    <meta property="og:image" content="/favicon.ico" />
    <meta property="og:url" content="https://gera2.by" />
    <meta property="og:type" content="product" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Гера2 – Пескоструйный аппарат" />
    <meta
      name="twitter:description"
      content="Гера2 – надежное и эффективное решение для пескоструйной обработки."
    />
    <meta name="twitter:image" content="/favicon.ico" />
    <link rel="preload" as="image" href={bgPrimary960.src} media="(max-width: 767px)" />
    <link rel="preload" as="image" href={bgPrimary1600.src} media="(min-width: 768px), (min-resolution: 2dppx)" />
    <link rel="preload" as="image" href={bgSecondary.src} />
    <link rel="icon" type="image/ico" href="/favicon.ico" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
    scrollbar-gutter: stable;
  }

  body {
    position: relative;
    min-height: 100vh;
    isolation: isolate;
    background: transparent;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background-image: url("../assets/backgroundPrimary-960.avif");
    background-repeat: no-repeat;
    background-position: top center;
    background-size: cover;
  }

  @media (min-width: 768px), (min-resolution: 2dppx) {
    body::before {
      background-image: url("../assets/backgroundPrimary-1600.avif");
    }
  }
</style>
