---
interface Props {
  image: ImageMetadata;
  name: string;
  description: string;
  index: number;
}

const { image, name, description, index } = Astro.props;
---

<button
  type="button"
  class="config_mode_card"
  data-mode-card
  data-tool-index={index}
  aria-pressed="false"
>
  <img
    class="config_mode_image"
    src={image.src}
    width={image.width}
    height={image.height}
    alt={`Аппарат ${name}`}
    loading="lazy"
    decoding="async"
  />
  <span class="config_mode_name" data-mode-name>{name}</span>
  <span class="config_mode_description">{description}</span>
</button>

<style>
  .config_mode_card {
    position: relative;
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(8, 8, 8, 0.25);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 30px rgba(10, 10, 207, 0.3);
    padding: 18px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .config_mode_card:hover {
    transform: translateY(-4px) scale(1.02);
  }

  .config_mode_card:focus-visible {
    outline: 2px solid rgba(28, 143, 225, 0.95);
    outline-offset: 2px;
  }

  .config_mode_card.is-selected {
    border-color: rgba(28, 143, 225, 0.95);
    background: rgba(212, 239, 255, 0.75);
    box-shadow:
      0 0 0 3px rgba(28, 143, 225, 0.55),
      0 16px 34px rgba(10, 10, 207, 0.35);
    transform: translateY(-3px) scale(1.01);
  }

  .config_mode_card.is-selected::after {
    content: "Выбрано";
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    background: #1c8fe1;
    border-radius: 999px;
    padding: 6px 10px;
    box-shadow: 0 6px 14px rgba(10, 10, 207, 0.35);
  }

  .config_mode_image {
    width: 120px;
    height: 200px;
    object-fit: contain;
  }

  .config_mode_name {
    font-size: 34px;
    font-weight: 700;
    text-transform: uppercase;
    color: #b05aae;
    text-align: center;
    border-bottom: 2px solid transparent;
    padding-bottom: 6px;
    line-height: 1.1;
  }

  .config_mode_name.is-underlined {
    border-bottom-color: #b05aae;
  }

  .config_mode_card.is-selected .config_mode_name {
    color: #8b2f89;
  }

  .config_mode_description {
    font-size: 17px;
    line-height: 1.3;
    color: #080808;
    text-align: center;
    text-wrap: balance;
  }

  @media (max-width: 660px) {
    .config_mode_name {
      font-size: 28px;
    }

    .config_mode_description {
      font-size: 15px;
    }
  }
</style>
