---
interface Price {
  RU: number;
  BY: number;
}

interface Props {
  image: ImageMetadata;
  label: number;
  text: string;
  price: Price;
  toolIndex: number;
  optionIndex: number;
}

const { image, label, text, price, toolIndex, optionIndex } = Astro.props;
---

<button
  type="button"
  class="config_option_card"
  data-option-card
  data-tool-index={toolIndex}
  data-option-index={optionIndex}
  aria-pressed="false"
>
  <img
    class="config_option_image"
    src={image.src}
    width={image.width}
    height={image.height}
    alt={`Комплектация ${label}`}
    loading="lazy"
    decoding="async"
  />
  <span class="config_option_label">Комплектация {label}</span>
  <span class="config_option_text">{text}</span>
  <span class="config_option_price" data-only="by" style="display: none;">
    {price.BY} BYN
  </span>
  <span class="config_option_price" data-only="other">{price.RU} RUB</span>
</button>

<style>
  .config_option_card {
    position: relative;
    width: 100%;
    min-height: 100%;
    border: 1px solid rgba(8, 8, 8, 0.25);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 30px rgba(10, 10, 207, 0.3);
    padding: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    text-align: center;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .config_option_card:hover {
    transform: translateY(-4px) scale(1.02);
  }

  .config_option_card:focus-visible {
    outline: 2px solid rgba(28, 143, 225, 0.95);
    outline-offset: 2px;
  }

  .config_option_card.is-selected {
    border-color: rgba(28, 143, 225, 0.95);
    background: rgba(212, 239, 255, 0.75);
    box-shadow:
      0 0 0 3px rgba(28, 143, 225, 0.55),
      0 16px 34px rgba(10, 10, 207, 0.35);
    transform: translateY(-3px) scale(1.01);
  }

  .config_option_card.is-selected::after {
    content: "Выбрано";
    position: absolute;
    top: 10px;
    right: 10px;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    background: #1c8fe1;
    border-radius: 999px;
    padding: 6px 10px;
    box-shadow: 0 6px 14px rgba(10, 10, 207, 0.35);
  }

  .config_option_image {
    width: 150px;
    height: 150px;
    object-fit: contain;
  }

  .config_option_label {
    font-size: 18px;
    line-height: 1.2;
    color: #080808;
    font-weight: 700;
    text-transform: uppercase;
  }

  .config_option_text {
    font-size: 16px;
    line-height: 1.3;
    color: #080808;
    text-wrap: balance;
  }

  .config_option_price {
    font-size: 26px;
    line-height: 1;
    color: #b05aae;
    font-weight: 700;
  }

  .config_option_card.is-selected .config_option_label {
    color: #0d3f61;
  }

  .config_option_card.is-selected .config_option_price {
    color: #8b2f89;
  }

  @media (max-width: 660px) {
    .config_option_image {
      width: 130px;
      height: 130px;
    }

    .config_option_label {
      font-size: 17px;
    }

    .config_option_text {
      font-size: 15px;
    }

    .config_option_price {
      font-size: 23px;
    }
  }
</style>
