---
import { TOOL_OPTIONS } from "../../shared/data/mediaSectionData";
import ComplectationOptionCard from "./ComplectationOptionCard.astro";
---

<section class="configurator_block" data-complectation-block hidden>
  <h4 class="configurator_title">2. Выберите комплектацию</h4>
  {
    TOOL_OPTIONS.map(({ options }, toolIndex) => (
      <div class="configurator_grid_option" data-tool-group={toolIndex} hidden>
        {options.map((option, optionIndex) => (
          <ComplectationOptionCard
            image={option.optionImage}
            label={optionIndex + 1}
            text={option.text}
            price={option.price}
            toolIndex={toolIndex}
            optionIndex={optionIndex}
          />
        ))}
      </div>
    ))
  }
</section>

<style>
  .configurator_block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .configurator_block[hidden] {
    display: none !important;
  }

  .configurator_title {
    font-size: 34px;
    text-transform: uppercase;
    color: #080808;
    text-align: center;
    line-height: 1.1;
  }

  .configurator_grid_option {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .configurator_grid_option[hidden] {
    display: none !important;
  }

  @media (max-width: 1100px) {
    .configurator_grid_option {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .configurator_title {
      font-size: 28px;
    }

    .configurator_grid_option {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
