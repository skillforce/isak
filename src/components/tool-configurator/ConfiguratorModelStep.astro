---
import { TOOL_OPTIONS } from "../../shared/data/mediaSectionData";
import ModeOptionCard from "./ModeOptionCard.astro";
---

<section class="configurator_block">
  <h4 class="configurator_title">1. Выберите модель</h4>
  <div class="configurator_grid_mode">
    {
      TOOL_OPTIONS.map(({ toolName, toolDescription, image }, index) => (
        <ModeOptionCard
          image={image}
          name={toolName}
          description={toolDescription}
          index={index}
        />
      ))
    }
  </div>
  <p class="configurator_note">*На картинке представлена максимальная комплектация.</p>
</section>

<style>
  .configurator_block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .configurator_title {
    font-size: 34px;
    text-transform: uppercase;
    color: #080808;
    text-align: center;
    line-height: 1.1;
  }

  .configurator_grid_mode {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .configurator_note {
    font-size: 16px;
    line-height: 1.35;
    color: #080808;
    opacity: 0.82;
    text-align: center;
  }

  @media (max-width: 1100px) {
    .configurator_grid_mode {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 760px) {
    .configurator_title {
      font-size: 28px;
    }

    .configurator_grid_mode {
      grid-template-columns: minmax(0, 1fr);
    }

    .configurator_note {
      font-size: 14px;
    }
  }
</style>
