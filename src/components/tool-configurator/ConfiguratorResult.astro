---
interface Props {
  toolName: string;
  optionText: string;
  optionImage: ImageMetadata;
  optionPriceBy: number;
  optionPriceRu: number;
}

const { toolName, optionText, optionImage, optionPriceBy, optionPriceRu } =
  Astro.props;
---

<section class="configurator_block" data-result-block hidden>
  <h4 class="configurator_title">3. Ваш выбор</h4>

  <figure class="configurator_result_figure">
    <img
      class="configurator_result_image_option"
      data-summary-option-image
      src={optionImage.src}
      width={optionImage.width}
      height={optionImage.height}
      alt="Выбранная комплектация"
      loading="lazy"
      decoding="async"
    />
  </figure>

  <div class="configurator_result_info">
    <p class="configurator_result_name" data-summary-tool-name>{toolName}</p>
    <p class="configurator_result_text" data-summary-option-text>{optionText}</p>
    <p class="configurator_result_price">
      <span data-summary-price-by data-only="by" style="display: none;">
        {optionPriceBy} BYN
      </span>
      <span data-summary-price-other data-only="other">{optionPriceRu} RUB</span>
    </p>
    <p class="configurator_result_note">
      *Пожалуйста, назовите модель и конфигурацию продавцу при заказе
    </p>
  </div>
</section>

<style>
  .configurator_block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .configurator_block[hidden] {
    display: none !important;
  }

  .configurator_title {
    font-size: 34px;
    text-transform: uppercase;
    color: #080808;
    text-align: center;
    line-height: 1.1;
  }

  .configurator_result_figure {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 5px 0 40px 0;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 30px rgba(10, 10, 207, 0.3);
  }

  .configurator_result_image_option {
    width: 380px;
    height: 380px;
    object-fit: contain;
  }

  .configurator_result_info {
    padding: 30px 24px;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(10, 10, 207, 0.3);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .configurator_result_name {
    font-size: 48px;
    line-height: 1.1;
    text-transform: uppercase;
    color: #b05aae;
    text-align: center;
    font-weight: 700;
  }

  .configurator_result_text {
    font-size: 24px;
    line-height: 1.3;
    text-align: center;
    color: #080808;
    text-wrap: balance;
  }

  .configurator_result_price {
    font-size: 44px;
    line-height: 1;
    color: #b05aae;
    text-align: center;
    font-weight: 700;
    text-transform: uppercase;
  }

  .configurator_result_note {
    font-size: 18px;
    line-height: 1.35;
    color: #080808;
    opacity: 0.82;
    text-align: center;
  }

  @media (max-width: 760px) {
    .configurator_title {
      font-size: 28px;
    }

    .configurator_result_name {
      font-size: 38px;
    }

    .configurator_result_text {
      font-size: 20px;
    }

    .configurator_result_price {
      font-size: 34px;
    }

    .configurator_result_note {
      font-size: 16px;
    }

    .configurator_result_image_option {
      width: 340px;
      height: 340px;
    }
  }
</style>
