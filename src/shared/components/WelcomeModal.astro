---
import {
  Modal as FreeModal,
  ModalBody,
  ModalHeader,
} from "free-astro-components";

import politicsPdf from "../../assets/politics/politics.pdf";

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<FreeModal id={id} class="welcome_modal">
  <ModalHeader>Добро пожаловать!</ModalHeader>
  <ModalBody>
    <div class="welcome_modal_body">
      <div class="welcome_modal_text">
        Для корректной работы сайта и вашего удобства мы используем файлы
        cookie.
      </div>
      <div class="welcome_modal_text">
        Нажимая «Принять» или пользуясь этим сайтом, вы даёте согласие на обработку персональных данных и
        файлов cookie в соответствии с{" "}
        <a href={politicsPdf} target="_blank" rel="noopener noreferrer">
          Политикой обработки
        </a>
        этих данных.
      </div>
    </div>
    <div class="welcome_modal_button_container">
      <button class="accept_button" data-modal-close>Принять</button>
    </div>
  </ModalBody>
</FreeModal>

<script define:vars={{ id }}>
  const onDOMReady = (callback) => {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", callback, { once: true });
      return;
    }
    callback();
  };

  const isIOS164OrLower = () => {
    const ua = navigator.userAgent;
    const isIOSDevice =
      /iP(ad|hone|od)/.test(ua) ||
      (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);

    if (!isIOSDevice) return false;

    const osMatch = ua.match(/OS (\d+)[._](\d+)/);
    if (osMatch) {
      const major = Number(osMatch[1]);
      const minor = Number(osMatch[2]);
      return major < 16 || (major === 16 && minor <= 4);
    }

    const versionMatch = ua.match(/Version\/(\d+)\.(\d+)/);
    if (!versionMatch) return false;

    const major = Number(versionMatch[1]);
    const minor = Number(versionMatch[2]);
    return major < 16 || (major === 16 && minor <= 4);
  };

  const resetModalState = (modal) => {
    modal.classList.add("ac-modal--close");
    modal.style.removeProperty("transform");
    modal.style.removeProperty("opacity");
    modal.style.removeProperty("transition");
    document.body.style.overflow = "auto";
    document.documentElement.style.overflow = "auto";
  };

  const disableLibraryTouchControls = (modal) => {
    modal.removeEventListener("touchstart", modal.handleTouchStart);
    modal.removeEventListener("touchmove", modal.handleTouchMove);
    modal.removeEventListener("touchend", modal.handleTouchEnd);
  };

  const hardHideModal = (modal) => {
    modal.setAttribute("hidden", "");
    modal.style.display = "none";
    modal.style.pointerEvents = "none";
  };

  const hardShowModal = (modal) => {
    modal.removeAttribute("hidden");
    modal.style.removeProperty("display");
    modal.style.removeProperty("pointer-events");
  };

  const setupModalIOSFallback = (modalId) => {
    const modal = document.getElementById(modalId);
    if (!(modal instanceof HTMLDialogElement)) return;

    if (!isIOS164OrLower()) return;

    const syncVisibilityState = () => {
      if (modal.open) {
        modal.classList.remove("ac-modal--close");
        hardShowModal(modal);
        disableLibraryTouchControls(modal);
        return;
      }

      resetModalState(modal);
      hardHideModal(modal);
    };

    modal.addEventListener("close", () => {
      resetModalState(modal);
      hardHideModal(modal);
    });

    const forceClose = () => {
      let closedNatively = false;
      try {
        if (modal.open) {
          modal.close();
          closedNatively = true;
        }
      } catch {
        closedNatively = false;
      }

      modal.removeAttribute("open");
      resetModalState(modal);

      if (!closedNatively) {
        modal.dispatchEvent(new Event("close"));
      }
    };

    modal
      .querySelectorAll("[data-modal-close]")
      .forEach((control) => {
        control.addEventListener(
          "touchend",
          (event) => {
            event.preventDefault();
            forceClose();
          },
          { passive: false }
        );
      });

    const observer = new MutationObserver(() => {
      syncVisibilityState();
    });

    observer.observe(modal, {
      attributes: true,
      attributeFilter: ["open"],
    });

    syncVisibilityState();
  };

  onDOMReady(() => setupModalIOSFallback(id));
</script>

<style>
  :global(.welcome_modal[hidden]) {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  :global(.welcome_modal.ac-modal--close) {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  :global(.welcome_modal:not([open])) {
    display: none !important;
  }

  :global(.welcome_modal) {
    background: rgb(0, 75, 164);
    background: radial-gradient(
      circle,
      rgba(0, 75, 164, 1) 3%,
      rgba(109, 123, 240, 1) 100%
    );
    opacity: 0.95;
    border-radius: 4px;
  }

  :global(.welcome_modal .ac-modal-close) {
    color: #ffffff;
  }

  :global(.welcome_modal .ac-modal-header) {
    color: #ffffff;
    font-family: "Sansation", sans-serif;
    font-weight: bold;
    font-size: 22px;
    display: flex;
    justify-content: center;
  }

  .welcome_modal_body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 5px;
    padding: 15px 0;
    letter-spacing: 1px;
  }

  .welcome_modal_text {
    color: #ffffff;
    font-size: 18px;
    text-align: start;
    text-wrap: balance;

  }

  .welcome_modal_text a {
    color: #ffffff;
    font-size: 19px;
    font-weight: bold;
    text-decoration: underline;
  }
  .welcome_modal_button_container {
    display: flex;
    justify-content: center;
  }

  .accept_button {
    color: rgb(0, 75, 164);
    font-weight: 600;
    padding: 5px 10px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 18px;
  }
</style>
