---
import {
  Modal as FreeModal,
  ModalBody,
  ModalHeader,
} from "free-astro-components";

import { MODAL_DATA } from "../data/modal_data";
import ContactLink from "./ContactLink.astro";

interface Props {
  id: string;
}
const { id } = Astro.props;
---

<script>
  import type { ContactType } from "../data/modal_data.ts";


  function buildMessage({ toolName }: { toolName: string }) {
    return `Здравствуйте! Хотел бы заказать ${toolName}.`
  }

  function buildLink(type:ContactType, base:string, message:string) {
    const text = encodeURIComponent(message);

    switch (type) {
      case "whatsapp":
        return `${base}?text=${text}`;

      case "telegram":
        return `${base}&text=${text}&profile`;

      case "viber":
        return `${base}&draft=${text}`;

      default:
        return base;
    }
  }
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const trigger = target.closest("[data-modal-trigger]");
    if (!(trigger instanceof HTMLElement)) return;
    if (!trigger) return;

    const data = {
      toolName: trigger.dataset.modalName,
    };

    if (!data.toolName) return;

    const message = buildMessage(data);
    console.log(message);

    document.querySelectorAll<HTMLAnchorElement>("[data-contact-type]").forEach((link) => {
      const type = link.dataset!.contactType;
      const base = link.dataset!.contactBase;
      if (!type || !base) return;

      link.href = buildLink(type, base, message);
    });
  });
</script>


<FreeModal id={id} class="contact_modal">
  <ModalHeader> Наши контакты : </ModalHeader>
  <ModalBody>
    <div class="contact_modal_body">
      {
        MODAL_DATA.CONTACTS.map((contact) => (
          <ContactLink
            href={contact.href}
            icon={contact.icon}
            label={contact.label}
            data-contact-type={contact.type}
            data-contact-base={contact.href}

          />
        ))
      }
    </div>
  </ModalBody>
</FreeModal>

<script define:vars={{ id }}>
  const onDOMReady = (callback) => {
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", callback, { once: true });
      return;
    }
    callback();
  };

  const isIOS164OrLower = () => {
    const ua = navigator.userAgent;
    const isIOSDevice =
      /iP(ad|hone|od)/.test(ua) ||
      (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);

    if (!isIOSDevice) return false;

    const osMatch = ua.match(/OS (\d+)[._](\d+)/);
    if (osMatch) {
      const major = Number(osMatch[1]);
      const minor = Number(osMatch[2]);
      return major < 16 || (major === 16 && minor <= 4);
    }

    const versionMatch = ua.match(/Version\/(\d+)\.(\d+)/);
    if (!versionMatch) return false;

    const major = Number(versionMatch[1]);
    const minor = Number(versionMatch[2]);
    return major < 16 || (major === 16 && minor <= 4);
  };

  const resetModalState = (modal) => {
    modal.classList.add("ac-modal--close");
    modal.style.removeProperty("transform");
    modal.style.removeProperty("opacity");
    modal.style.removeProperty("transition");
    document.body.style.overflow = "auto";
    document.documentElement.style.overflow = "auto";
  };

  const disableLibraryTouchControls = (modal) => {
    modal.removeEventListener("touchstart", modal.handleTouchStart);
    modal.removeEventListener("touchmove", modal.handleTouchMove);
    modal.removeEventListener("touchend", modal.handleTouchEnd);
  };

  const hardHideModal = (modal) => {
    modal.setAttribute("hidden", "");
    modal.style.display = "none";
    modal.style.pointerEvents = "none";
  };

  const hardShowModal = (modal) => {
    modal.removeAttribute("hidden");
    modal.style.removeProperty("display");
    modal.style.removeProperty("pointer-events");
  };

  const setupModalIOSFallback = (modalId) => {
    const modal = document.getElementById(modalId);
    if (!(modal instanceof HTMLDialogElement)) return;

    if (!isIOS164OrLower()) return;

    const syncVisibilityState = () => {
      if (modal.open) {
        modal.classList.remove("ac-modal--close");
        hardShowModal(modal);
        disableLibraryTouchControls(modal);
        return;
      }

      resetModalState(modal);
      hardHideModal(modal);
    };

    modal.addEventListener("close", () => {
      resetModalState(modal);
    });

    const forceClose = () => {
      let closedNatively = false;
      try {
        if (modal.open) {
          modal.close();
          closedNatively = true;
        }
      } catch {
        closedNatively = false;
      }

      modal.removeAttribute("open");
      resetModalState(modal);

      if (!closedNatively) {
        modal.dispatchEvent(new Event("close"));
      }
    };

    modal
      .querySelectorAll("[data-modal-close]")
      .forEach((control) => {
        control.addEventListener(
          "touchend",
          (event) => {
            event.preventDefault();
            forceClose();
          },
          { passive: false }
        );
      });

    const observer = new MutationObserver(() => {
      syncVisibilityState();
    });

    observer.observe(modal, {
      attributes: true,
      attributeFilter: ["open"],
    });

    syncVisibilityState();
  };

  onDOMReady(() => setupModalIOSFallback(id));
</script>

<style>
  :global(.contact_modal[hidden]) {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  :global(.contact_modal.ac-modal--close) {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  :global(.contact_modal:not([open])) {
    display: none !important;
  }

  :global(.contact_modal) {
    background: rgb(0, 75, 164);
    background: -moz-radial-gradient(
      circle,
      rgba(0, 75, 164, 1) 3%,
      rgba(109, 123, 240, 1) 100%
    );
    background: -webkit-radial-gradient(
      circle,
      rgba(0, 75, 164, 1) 3%,
      rgba(109, 123, 240, 1) 100%
    );
    background: radial-gradient(
      circle,
      rgba(0, 75, 164, 1) 3%,
      rgba(109, 123, 240, 1) 100%
    );
    filter: progid:DXImageTransform.Microsoft.gradient(startColorstr="#004ba4",endColorstr="#6d7bf0",GradientType=1);
    -webkit-box-shadow: 33px -16px 47px -1px rgba(97, 127, 244, 1);
    -moz-box-shadow: 33px -16px 47px -1px rgba(97, 127, 244, 1);
    box-shadow: 33px -16px 47px -1px rgba(97, 127, 244, 1);
    opacity: 0.95;
    border-radius: 4px;
  }

  :global(.contact_modal .ac-modal-close) {
    color: #ffffff;
  }

  :global(.contact_modal .ac-modal-header) {
    color: #ffffff;
    font-family: "Sansation", sans-serif;
    font-weight: bold;
    font-size: 22px;
    display: flex;
    justify-content: center;
  }

  .contact_modal_body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 10px;
  }
</style>
